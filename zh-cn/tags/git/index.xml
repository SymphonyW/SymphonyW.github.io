        &lt;span style=&#34;display: block; margin-top: 10px; color: #666; font-size: 0.9em;&#34;&gt;创建新分支&lt;/span&gt;
    
&lt;/div&gt;
&lt;div class=&#34;post-image-container&#34; style=&#34;margin: 15px auto; text-align: center; width: 85%;&#34;&gt;
    
    &lt;a href=&#34;practice_6.png&#34; 
        
       target=&#34;_blank&#34; 
